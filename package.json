{
  "name": "lovelace-equitherm-cards",
  "version": "1.0.1",
  "description": "Home Assistant Lovelace cards for ESPHome equitherm climate component",
  "author": "P4uLT",
  "license": "MIT",
  "private": true,
  "main": "dist/equitherm-cards.js",
  "scripts": {
    "start": "rollup -c --watch --bundleConfigAsCjs",
    "build": "rollup -c --bundleConfigAsCjs",
    "format": "prettier --write .",
    "start:hass-stable": "docker run --rm -p8123:8123 -v ./.hass_dev:/config homeassistant/home-assistant:stable",
    "start:hass": "docker run --rm -p8123:8123 -v ./.hass_dev:/config homeassistant/home-assistant:beta",
    "start:hass-dev": "docker run --rm -p8123:8123 -v ./.hass_dev:/config homeassistant/home-assistant:dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@equitherm/core": "^0.1.5",
    "apexcharts": "^3.54.0",
    "custom-card-helpers": "^1.9.0",
    "intl-messageformat": "^11.1.3",
    "lit": "^3.3.1",
    "memoize-one": "^6.0.0",
    "superstruct": "^2.0.2"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-serve": "^3.0.0",
    "tslib": "^2.8.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.30.3"
}
